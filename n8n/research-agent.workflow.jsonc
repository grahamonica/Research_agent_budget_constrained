// Purpose: Define the n8n workflow that owns the research stages and pushes live updates back into FastAPI.
//
// Setup:
//   1. FastAPI POSTs new sessions to /webhook/research-session.
//   2. n8n initializes session state, runs the research stages as workflow nodes,
//      and POSTs progress snapshots into the FastAPI webhook supplied in the trigger body.
//   3. FastAPI remains the thin app-facing API and SSE layer.

{
  "name": "Research Agent",
  "nodes": [
    {
      "id": "b1c2d3e4-0001-4000-8000-000000000001",
      "name": "Session Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "webhookId": "research-session-trigger",
      "position": [240, 260],
      "parameters": {
        "path": "research-session",
        "httpMethod": "POST",
        "responseMode": "onReceived",
        "options": {}
      }
    },
    {
      "id": "b1c2d3e4-0002-4000-8000-000000000002",
      "name": "Initialize Session State",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [520, 260],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const body = $input.first().json.body || $input.first().json; const sessionId = String(body.session_id || '').trim(); const query = String(body.query || '').trim(); const webhookUrl = String(body.fastapi_webhook_url || '').trim(); if (!sessionId) throw new Error('session_id is required'); if (!query) throw new Error('query is required'); if (!webhookUrl) throw new Error('fastapi_webhook_url is required'); const num = (value, fallback) => { const parsed = Number(value); return Number.isFinite(parsed) ? parsed : fallback; }; const budgetCap = num(body.budget_cap_usd, 0.05); const state = { session_id: sessionId, query, fastapi_webhook_url: webhookUrl, settings: { max_subquestions: Math.max(1, Math.floor(num(body.max_subquestions, 3))), max_papers_per_subquestion: Math.max(1, Math.floor(num(body.max_papers_per_subquestion, 3))), max_chunks_per_paper: Math.max(1, Math.floor(num(body.max_chunks_per_paper, 3))) }, status: 'queued', active_stage: 'created', budget: { cap_usd: budgetCap, spent_usd: 0, remaining_usd: budgetCap, estimated_next_step_usd: 0, active_allocation_key: null, allocations: [] }, subquestions: [], findings: [], final_answer: null, runtime: { completed_sq_ids: [], partial_sq_ids: [], branches: {} } }; state.state_b64 = Buffer.from(JSON.stringify(state)).toString('base64url'); return [{ json: state }];"
      }
    },
    {
      "id": "b1c2d3e4-0003-4000-8000-000000000003",
      "name": "Decompose Query",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [800, 260],
      "parameters": {
        "executeOnce": true,
        "command": "={{ 'node /workflows/runtime/research_stage_runner.js decompose ' + $json.state_b64 }}"
      }
    },
    {
      "id": "b1c2d3e4-0004-4000-8000-000000000004",
      "name": "Parse Decompose State",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1080, 260],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const stdout = String($input.first().json.stdout || '').trim(); if (!stdout) throw new Error('Stage runner returned empty stdout.'); const state = JSON.parse(stdout); state.state_b64 = Buffer.from(JSON.stringify(state)).toString('base64url'); return [{ json: state }];"
      }
    },
